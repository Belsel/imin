# Neon Postgres (Vercel Marketplace / neon.tech) — convert the connection
# string Neon gives you (postgres://user:pass@host/db?sslmode=require) into:
DATABASE_URL=jdbc:postgresql://<host>/<db>?sslmode=require
DATABASE_USERNAME=<user>
DATABASE_PASSWORD=<pass>

# HMAC signing secret for self-issued JWTs (32+ random bytes, never commit a real one)
JWT_SECRET=change-me-to-a-long-random-value

# Google OAuth2 login (Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where the frontend is served from (used for CORS + OAuth2 redirect target)
FRONTEND_URL=http://localhost:5173

# Resend (https://resend.com) — transactional email for verification links
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@example.com

# OpenRouteService (https://openrouteservice.org) — turn-by-turn routing,
# called server-side only via RoutingController/RoutingService so this key
# never ships in the frontend bundle (see specs/mvp/design.md §6a)
ORS_API_KEY=

# Render injects PORT automatically in production; default is for local dev
PORT=8080

# Shared "Try demo account" login (public by design — see
# specs/try-demo-account/spec.md). Override only if you want a different
# fixed demo persona; the defaults work out of the box.
DEMO_ACCOUNT_EMAIL=demo@imin.app
DEMO_ACCOUNT_PASSWORD=ImInDemo2026!
DEMO_ACCOUNT_DISPLAY_NAME=Demo User
